@page
@model impulse_spending_tracker.Areas.Identity.Pages.Account.SetIncomeModel
@{
    ViewData["Title"] = "Set Monthly Income";
}

<div class="form-shell">
    <div class="form-surface card border-0 shadow-sm mx-auto" style="max-width: 640px;">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3 mb-2">Almost done — one more step</h1>
            <p class="text-muted mb-4">Please tell us your monthly net income so we can personalize your experience.</p>

            <form method="post" asp-route-userId="@Model.UserId" asp-route-returnUrl="@Model.ReturnUrl">
                <div asp-validation-summary="All" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Input.MonthlyNetIncome" class="form-label"></label>
                    <input asp-for="Input.MonthlyNetIncome" class="form-control" />
                    <span asp-validation-for="Input.MonthlyNetIncome" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">Save and continue</button>
                </div>
            </form>
        </div>
    </div>
</div>
