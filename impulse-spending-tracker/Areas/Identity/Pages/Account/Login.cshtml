@page
@model impulse_spending_tracker.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Spendora";
}

<style>
    .auth-btn-google{
        background: #fff; color:#1f2937; border:1px solid #e5e7eb; border-radius:10px; padding:0.55rem 0.9rem;
    }
    .auth-btn-google:hover{ box-shadow: 0 6px 18px rgba(15,23,42,0.06); }
    .form-surface .form-control::placeholder{ color: #9ca3af; }
    @@media (max-width: 767px){ .auth-btn-google{ width:100%; display:block; } }
    .google-word .g{ color:#4285F4; }
    .google-word .o1{ color:#DB4437; }
    .google-word .o2{ color:#F4B400; }
    .google-word .g2{ color:#4285F4; }
    .google-word .l{ color:#0F9D58; }
    .google-word .e{ color:#DB4437; }
</style>

<div class="form-shell">
    <div class="row g-4 align-items-center justify-content-center">
        <div class="col-12 col-lg-5">
            <div class="p-4 rounded-3" style="background: linear-gradient(180deg, rgba(15,118,110,0.08), rgba(15,118,110,0.03));">
                <div class="d-flex align-items-center gap-3">
                    <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index" style="text-decoration:none;">
                        <span class="app-brand__mark" aria-hidden="true">S</span>
                        <span class="app-brand__text" style="margin-left:0.6rem;">
                            <span class="app-brand__title">Spendora</span>
                        </span>
                    </a>
                </div>
                <div class="mt-3">
                    <p class="text-muted mb-2">Sign in to access your purchases, budgets and insights.</p>
                    <ul class="list-unstyled small text-muted mb-0">
                        <li>• Secure sign-in with email or Google.</li>
                        <li>• Keep your personalised data synced across devices.</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-7">
            <section class="form-surface card border-0 shadow-sm mx-auto">
                <div class="card-body p-4 p-md-5">
                    <form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="row g-3" novalidate>
                        <div asp-validation-summary="All" class="text-danger mb-2"></div>


                        <div class="col-12">
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="e.g., jane.doe@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Input.Password" class="form-label">Password</label>
                            <input asp-for="Input.Password" class="form-control" placeholder="Enter your password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Input.RememberMe" class="form-check-input" />
                                <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
                            </div>
                        </div>

                        <div class="col-12 d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Log in</button>
                        </div>
                    </form>

                    <div class="border-top pt-3 mt-3">
                        <div class="d-flex gap-2 flex-column flex-sm-row">
                            <a class="btn btn-light border d-inline-flex align-items-center justify-content-center auth-btn-google" href="@Url.Action("Google", "ExternalAuth", new { returnUrl = Model.ReturnUrl })">
                                <span class="me-2" aria-hidden="true">
                                    <!-- simple Google 'G' mark -->
                                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <path d="M17.64 9.20454C17.64 8.56818 17.5827 7.96364 17.4773 7.38636H9V11.0227H13.8436C13.6955 12.0909 13.0455 13.0227 12.0455 13.5682V15.8182H15.0636C16.86 14.0682 17.64 11.8182 17.64 9.20454Z" fill="#4285F4"/>
                                        <path d="M9 18C11.43 18 13.4273 17.1364 14.9436 15.8182L12.0455 13.5682C11.2045 14.1364 10.1636 14.4318 9 14.4318C6.60909 14.4318 4.58182 12.715 3.93636 10.5227H0.78125V12.8182C2.29545 15.9318 5.82727 18 9 18Z" fill="#34A853"/>
                                        <path d="M3.93636 10.5227C3.79545 10.0227 3.70455 9.49545 3.70455 8.95455C3.70455 8.41364 3.79545 7.88636 3.93636 7.38636V5.09H0.78125C0.272727 6.45 0 7.92727 0 9.45455C0 10.9818 0.272727 12.4591 0.78125 13.8182L3.93636 10.5227Z" fill="#FBBC05"/>
                                        <path d="M9 3.56818C10.4909 3.56818 11.8273 4.04545 12.8182 4.97727L15.0455 2.79545C13.4273 1.31818 11.43 0.545455 9 0.545455C5.82727 0.545455 2.29545 2.61364 0.78125 5.72727L3.93636 8.02273C4.58182 5.83182 6.60909 4.11364 9 4.11364V3.56818Z" fill="#EA4335"/>
                                    </svg>
                                </span>
                                <span>Sign in with <span class="google-word"><span class="g">G</span><span class="o1">o</span><span class="o2">o</span><span class="g2">g</span><span class="l">l</span><span class="e">e</span></span></span>
                            </a>
                            <a class="btn btn-outline-secondary ms-sm-2" asp-page="/Account/Register">Create account</a>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
