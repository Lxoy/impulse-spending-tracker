@model TriggerType

@{
    ViewData["Title"] = "Trigger Type Details";
}

<div class="details-shell">
    <nav aria-label="breadcrumb" class="details-breadcrumb mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="TriggerTypes" asp-action="Index">Trigger Types</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <section class="details-hero mb-3">
        <p class="details-kicker">Classification Trigger Type</p>
        <h1 class="details-title">@Model.Name</h1>
        <p class="details-subtitle">Trigger type definition, visual color marker, and usage footprint across purchases.</p>
        <div class="details-chip-row">
            <span class="details-chip">@Model.Purchases.Count Purchases</span>
            <span class="details-chip">Color @Model.ColorHex</span>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Trigger Type Details</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>Color</dt>
                            <dd>
                                <span class="badge" style="background-color:@Model.ColorHex">@Model.ColorHex</span>
                            </dd>
                        </div>
                        <div class="details-row">
                            <dt>Description</dt>
                            <dd>@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>
                        </div>
                        <div class="details-row">
                            <dt>Purchase count</dt>
                            <dd>@Model.Purchases.Count</dd>
                        </div>
                    </dl>
                </div>
            </article>
        </div>

        <div class="col-12 col-lg-4">
            <aside class="details-aside mb-3">
                <h2 class="h6 mb-2">Quick Hint</h2>
                <p class="mb-0 text-muted">Use consistent trigger type color semantics so activity patterns are easier to scan in index tables and dashboards.</p>
            </aside>
        </div>
    </div>

    <div class="details-actions">
        @if (ViewBag.CanManageTag == true)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit trigger type</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        }
        <a asp-action="Index" class="btn btn-outline-primary">Back to list</a>
    </div>
</div>
