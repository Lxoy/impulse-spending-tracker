@model IReadOnlyList<TriggerType>

@{
    ViewData["Title"] = "Trigger Types";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Trigger Types</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="index-hero__grid">
            <div class="index-hero__copy">
                <p class="index-kicker mb-2">Classification</p>
                <h1 class="display-6 mb-2">Trigger Types</h1>
                <p class="text-muted mb-0">Classification of purchases by trigger and context.</p>
            </div>
            <div class="index-hero__actions">
                <span class="index-count-chip" id="tagCount" data-singular="trigger type" data-plural="trigger types">@Model.Count trigger types</span>
                @if (User.IsInRole("Admin"))
                {
                    <a class="btn btn-primary" asp-action="Create">Create trigger type</a>
                }
            </div>
        </div>

        <div class="index-search-panel">
            <div class="index-search-panel__header">
                <div>
                    <p class="index-search-panel__eyebrow mb-1">Live filter</p>
                    <p class="index-search-panel__title mb-0">Search by trigger type name</p>
                </div>
                <span class="index-search-panel__hint">Results update as you type</span>
            </div>
        <input type="text"
               class="form-control index-search-input"
               placeholder="Search by trigger type name..."
               aria-label="Search trigger types by name"
               data-ajax-filter
               data-url="@Url.Action("Filter", "TriggerTypes")"
               data-target="#tagTableBody"
               data-count-target="#tagCount"
               data-singular="trigger type"
               data-plural="trigger types"
               data-empty-message="No trigger types match your search."
               data-column-count="4" />
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No trigger types available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Trigger semantics</p>
                    <p class="index-table-note">Trigger type names, visual color markers, and how often each type appears in purchases.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Color</th>
                            <th>Purchase Count</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tagTableBody">
                    @await Html.PartialAsync("_TagTableRows", Model)
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>