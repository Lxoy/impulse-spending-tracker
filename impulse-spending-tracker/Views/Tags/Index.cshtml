@model IReadOnlyList<Tag>

@{
    ViewData["Title"] = "Tags";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Tags</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <div>
                <p class="index-kicker mb-2">Classification</p>
                <h1 class="display-6 mb-2">Tags</h1>
                <p class="text-muted mb-0">Classification of purchases by trigger and context.</p>
            </div>
            <span class="index-count-chip">@Model.Count tags</span>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No tags available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Semantic labels</p>
                    <p class="index-table-note">Tag names, visual color markers, and how often each tag appears in purchases.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Color</th>
                            <th>Purchase Count</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var tag in Model)
                    {
                        var purchaseCount = tag.Purchases.Count;
                        var usageSignalClass = purchaseCount switch
                        {
                            >= 5 => "list-signal list-signal--danger",
                            >= 3 => "list-signal list-signal--warn",
                            >= 1 => "list-signal list-signal--ok",
                            _ => "list-signal list-signal--muted"
                        };

                        <tr>
                            <td class="fw-semibold">
                                <a class="index-link" asp-action="Details" asp-route-id="@tag.Id">@tag.Name</a>
                            </td>
                            <td>
                                <span class="badge" style="background-color:@tag.ColorHex">@tag.ColorHex</span>
                            </td>
                            <td><span class="@usageSignalClass">@purchaseCount</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>