@model Merchant

@{
    ViewData["Title"] = "Merchant Details";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Merchants" asp-action="Index">Merchants</a></li>
        <li class="breadcrumb-item active" aria-current="page">Details</li>
    </ol>
</nav>

<section class="mb-4">
    <h1 class="display-6 mb-2">@Model.Name</h1>
    <p class="text-muted mb-0">Detaljni prikaz trgovca.</p>
</section>

<div class="card mb-3"><div class="card-body"><dl class="row mb-0">
    <dt class="col-sm-4 text-muted">Kategorija</dt>
    <dd class="col-sm-8 fw-semibold">@Model.Category</dd>
    <dt class="col-sm-4 text-muted">Drzava</dt>
    <dd class="col-sm-8 fw-semibold">@Model.CountryCode</dd>
    <dt class="col-sm-4 text-muted">Kanal</dt>
    <dd class="col-sm-8 fw-semibold">@(Model.IsOnlineOnly ? "Online" : "Online + Store")</dd>
    <dt class="col-sm-4 text-muted">Prosjecna dostava</dt>
    <dd class="col-sm-8 fw-semibold">@(Model.AverageDeliveryDays.HasValue ? $"{Model.AverageDeliveryDays} dana" : "-")</dd>
    <dt class="col-sm-4 text-muted">Broj kupnji</dt>
    <dd class="col-sm-8 fw-semibold">@Model.Purchases.Count</dd>
</dl></div></div>

<a asp-action="Index" class="btn btn-outline-primary">Natrag na listu</a>
