@model Merchant

@{
    ViewData["Title"] = "Merchant Details";
}

<div class="details-shell">
    <nav aria-label="breadcrumb" class="details-breadcrumb mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Merchants" asp-action="Index">Merchants</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <section class="details-hero mb-3">
        <p class="details-kicker">Merchant Profile</p>
        <h1 class="details-title">@Model.Name</h1>
        <p class="details-subtitle">Merchant exposure summary including channel type, category, and purchase count impact.</p>
        <div class="details-chip-row">
            <span class="details-chip">@Model.Category</span>
            <span class="details-chip">@Model.CountryCode</span>
            <span class="details-chip">@Model.Purchases.Count Purchases</span>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Merchant Details</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>Category</dt>
                            <dd>@Model.Category</dd>
                        </div>
                        <div class="details-row">
                            <dt>Country</dt>
                            <dd>@Model.CountryCode</dd>
                        </div>
                        <div class="details-row">
                            <dt>Channel</dt>
                            <dd>@(Model.IsOnlineOnly ? "Online" : "Online + Store")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Average delivery</dt>
                            <dd>@(Model.AverageDeliveryDays.HasValue ? $"{Model.AverageDeliveryDays} days" : "-")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Purchase count</dt>
                            <dd>@Model.Purchases.Count</dd>
                        </div>
                    </dl>
                </div>
            </article>
        </div>

        <div class="col-12 col-lg-4">
            <aside class="details-aside mb-3">
                <h2 class="h6 mb-2">Quick Hint</h2>
                <p class="mb-0 text-muted">Merchants with high purchase count and fast delivery often correlate with repeated impulse behavior.</p>
            </aside>
        </div>
    </div>

    <div class="details-actions">
        <a asp-action="Index" class="btn btn-outline-primary">Back to list</a>
    </div>
</div>
