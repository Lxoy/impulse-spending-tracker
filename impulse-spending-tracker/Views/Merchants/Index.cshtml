@model IReadOnlyList<Merchant>

@{
    ViewData["Title"] = "Merchants";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Merchants</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="index-hero__grid">
            <div class="index-hero__copy">
                <p class="index-kicker mb-2">Commerce map</p>
                <h1 class="display-6 mb-2">Merchants</h1>
                <p class="text-muted mb-0">Overview of merchants connected to user purchases.</p>
            </div>
            <div class="index-hero__actions">
                <span class="index-count-chip" id="merchantCount" data-singular="merchant" data-plural="merchants">@Model.Count merchants</span>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a class="btn btn-primary" asp-action="Create">Create merchant</a>
                }
            </div>
        </div>

        <div class="index-search-panel">
            <div class="index-search-panel__header">
                <div>
                    <p class="index-search-panel__eyebrow mb-1">Live filter</p>
                    <p class="index-search-panel__title mb-0">Search by merchant name</p>
                </div>
                <span class="index-search-panel__hint">Results update as you type</span>
            </div>
        <input type="text"
               id="merchantSearch"
               class="form-control index-search-input"
               placeholder="Search by merchant name..."
               aria-label="Search merchants by name"
               data-ajax-filter
               data-url="/api/merchants"
               data-target="#merchantTableBody"
               data-count-target="#merchantCount"
               data-singular="merchant"
               data-plural="merchants"
               data-empty-message="No merchants match your search."
             data-column-count="5"
             data-response-format="json"
             data-row-renderer="merchant" />
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No merchants available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Merchant network</p>
                    <p class="index-table-note">Merchant list sorted by name and category, including market and channel.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Country</th>
                            <th>Channel</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="merchantTableBody">
                    @await Html.PartialAsync("_MerchantTableRows", Model)
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
