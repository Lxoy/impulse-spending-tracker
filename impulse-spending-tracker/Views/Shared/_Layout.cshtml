<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Spendora</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/impulse_spending_tracker.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light app-navbar mb-3">
            <div class="container-fluid app-navbar__container">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="app-brand__mark" aria-hidden="true">S</span>
                    <span class="app-brand__text">
                        <span class="app-brand__title">Spendora</span>
                        <small class="app-brand__tag">Impulse spending tracker</small>
                    </span>
                </a>
                <button class="navbar-toggler app-navbar__toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNav" aria-controls="appNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse app-navbar__collapse" id="appNav">
                    <ul class="navbar-nav app-nav app-nav--primary">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="UserProfiles" asp-action="Index">User Profiles</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="BudgetPlans" asp-action="Index">Budget Plans</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Merchants" asp-action="Index">Merchants</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Purchases" asp-action="Index">Purchases</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav app-nav app-nav--secondary ms-lg-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="SpendingSessions" asp-action="Index">Sessions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Tags" asp-action="Index">Tags</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="WishlistItems" asp-action="Index">Wishlist</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer app-footer">
        <div class="container app-footer__container">
            <div class="app-footer__brand">
                <p class="app-footer__title mb-1">Spendora</p>
                <p class="app-footer__sentence mb-0">Track impulse triggers, purchase history, and budget intent in one calm dashboard.</p>
            </div>
            <div class="app-footer__meta">
                <span>&copy; @DateTime.Now.Year Spendora. All rights reserved.</span>
                <span class="app-footer__dot" aria-hidden="true">•</span>
                <span>Use the top navigation to explore entities and insights.</span>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
