@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@inject impulse_spending_tracker.Data.ImpulseSpendingDbContext Db

<ul class="navbar-nav app-nav app-nav--auth ms-lg-3">
@if (SignInManager.IsSignedIn(User))
{
    var displayName = UserManager.GetUserName(User);
    var currentUserId = UserManager.GetUserId(User);
    if (!string.IsNullOrEmpty(currentUserId))
    {
        var profile = Db.UserProfiles.FirstOrDefault(p => p.AppUserId == currentUserId);
        if (profile != null && !string.IsNullOrEmpty(profile.FirstName))
        {
            displayName = profile.FirstName;
        }
    }
    <li class="nav-item">
        <span class="nav-link app-nav__greeting text-dark">Hello, @displayName</span>
    </li>
    <li class="nav-item">
        <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")">
            <button type="submit" class="btn btn-link nav-link app-nav__logout text-dark">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>