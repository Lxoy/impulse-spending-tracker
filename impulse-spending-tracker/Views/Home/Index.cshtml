@model impulse_spending_tracker.Models.ImpulsePulseViewModel
@{
    ViewData["Title"] = "Home Page";
}

<div class="home-dashboard py-2 py-lg-4">
    <section class="home-hero card border-0">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-4 align-items-center">
                <div class="col-lg-7">
                    <p class="hero-badge mb-2">Spendora</p>
                    <h1 class="hero-title mb-3">See your spending patterns before they become habits.</h1>
                    <p class="hero-subtitle mb-4">
                        This tracker helps you connect mood, trigger type, and channel behavior so you can make smarter purchase decisions.
                    </p>
                    <div class="hero-actions d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" asp-controller="Purchases" asp-action="Index">Review Purchases</a>
                        <a class="btn btn-outline-primary" asp-controller="SpendingSessions" asp-action="Index">Open Session Insights</a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="hero-preview p-3 p-md-4">
                        <h2 class="h6 mb-3">Current snapshot</h2>
                        <div class="preview-row">
                            <span>Total users</span>
                            <strong>@Model?.TotalUsers</strong>
                        </div>
                        <div class="preview-row">
                            <span>Impulse purchases tracked</span>
                            <strong>@Model?.ImpulsePurchasesCount</strong>
                        </div>
                        <div class="preview-row">
                            <span>Avg risk score</span>
                            <strong>@String.Format("{0:0.0}", Model?.AvgRiskScore)</strong>
                        </div>
                        <div class="preview-row mb-0">
                            <span>Most common trigger</span>
                            <strong>@Model?.TopTriggerLabel</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="quick-metrics mt-4">
        <div class="row g-3">
            <div class="col-12 col-md-6 col-xl-3">
                <article class="metric-tile metric-a p-3 h-100">
                    <p class="metric-label mb-1">Monthly spend</p>
                    <p class="metric-value mb-1">@Model?.MonthlySpendCurrency @String.Format("{0:0.00}", Model?.TotalAmount)</p>
                    <p class="metric-delta mb-0">@Model?.MonthlySpendTrendText</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <article class="metric-tile metric-b p-3 h-100">
                    <p class="metric-label mb-1">Impulse events</p>
                    <p class="metric-value mb-1">@Model?.ImpulsePurchasesCount</p>
                    <p class="metric-delta mb-0">@Model?.ImpulsePurchasesThisWeek this week</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <article class="metric-tile metric-c p-3 h-100">
                    <p class="metric-label mb-1">Wishlist converted</p>
                    <p class="metric-value mb-1">@Model?.WishlistConvertedCount</p>
                    <p class="metric-delta mb-0">@Model?.WishlistConversionText</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <article class="metric-tile metric-d p-3 h-100">
                    <p class="metric-label mb-1">Average need level</p>
                    <p class="metric-value mb-1">@String.Format("{0:0.0}", Model?.AverageNeedLevel) / 10</p>
                    <p class="metric-delta mb-0">@Model?.AverageNeedLevelText</p>
                </article>
            </div>
        </div>
    </section>

    <section class="trigger-heatmap-panel mt-4 card border-0">
        <div class="card-body p-4">
            <div class="d-flex align-items-start justify-content-between mb-2">
                <div>
                    <h2 class="panel-title h5 mb-1">Trigger heatmap — last 30 days</h2>
                </div>
                <div class="small text-muted">Last 30 days</div>
            </div>

            <div class="heatmap-wrapper">
                <div class="heatmap-main">
                    <div class="heatmap-weekdays" aria-hidden="true">
                        <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
                    </div>
                    <div class="trigger-heatmap-grid" id="triggerHeatmapGrid" aria-label="Trigger intensity grid" role="list">
                        <!-- heatmap cells will be injected here -->
                    </div>
                </div>

                <aside class="trigger-legend mt-0" aria-hidden="true">
                    <small class="text-muted mb-2">Low</small>
                    <div class="legend-gradient" aria-hidden="true"></div>
                    <small class="text-muted mt-2">High</small>
                </aside>
            </div>

        </div>
    </section>

    <section class="impulse-pulse mt-4 card border-0">
        <div class="card-body p-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <div>
                    <h2 class="panel-title h5 mb-1">Impulse Pulse</h2>
                    <p class="panel-subtitle text-muted mb-0">A fast read of what most influenced spending decisions this month.</p>
                </div>
                <p class="panel-meta mb-0">Snapshot generated from current EF-backed application data.</p>
            </div>

            <div class="pulse-lanes" aria-label="Impulse pulse intensity by factor">
                @if (Model?.Items != null && Model.Items.Count > 0)
                {
                    foreach (var item in Model.Items)
                    {
                        var value = Math.Round(item.Percent);
                        var label = value >= 60 ? "High" : value >= 30 ? "Medium" : "Low";
                <div class="pulse-lane">
                    <span>@item.Label (@item.Count)</span>
                    <div class="pulse-track"><span class="pulse-fill" style="--pulse-value: @value%;"></span></div>
                    <strong>@label (@String.Format("{0:0}%", item.Percent))</strong>
                </div>
                    }
                }
                else
                {
                <div class="pulse-lane">
                    <span>No impulse purchases this month</span>
                    <div class="pulse-track"><span class="pulse-fill" style="--pulse-value: 0%;"></span></div>
                    <strong>—</strong>
                </div>
                }
            </div>
        </div>
    </section>

    <!-- route-cards removed per user request -->
</div>

@section Scripts {
    <style>
        .heatmap-wrapper { width:100%; max-width:1200px; margin-left:auto; margin-right:auto; display:flex; gap:18px; align-items:stretch; }
        .heatmap-main { flex:1; }
        .heatmap-weekdays { display:grid; grid-template-columns:repeat(7,1fr); gap:6px; margin-bottom:8px; }
        .heatmap-weekdays span { text-align:center; font-size:11px; color:var(--ui-text-muted); }

        .trigger-heatmap-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:6px; }
        .trigger-cell { width:100%; aspect-ratio:1 / 1; border-radius:6px; display:inline-flex; align-items:center; justify-content:center; font-size:12px; color:var(--ui-text-muted); position:relative; cursor:default; border:1px solid rgba(15,118,110,0.06); background-clip:padding-box; box-shadow: inset 0 1px 0 rgba(255,255,255,0.6); transition: background 260ms ease, transform 220ms ease, opacity 300ms ease; }
        .trigger-cell .day-label { font-size:12px; opacity:0.8; }
        .trigger-cell.today { box-shadow: inset 0 1px 0 rgba(255,255,255,0.6), 0 0 0 2px rgba(14,165,233,0.06); }

        /* tooltip removed by design; keep element hidden if present */
        .trigger-cell .tooltip { display:none !important; }

        .trigger-legend { display:flex; flex-direction:column; align-items:center; justify-content:stretch; width:48px; }
        .legend-gradient { width:14px; flex:1 1 auto; min-height:60px; border-radius:6px; border:1px solid rgba(15,118,110,0.08); background: linear-gradient(180deg, var(--ui-surface-soft), var(--ui-surface-soft), var(--ui-accent)); box-shadow: inset 0 1px 0 rgba(255,255,255,0.6); }

        @@media (max-width: 768px) {
            .heatmap-wrapper { max-width: 100%; display:block; }
            .heatmap-weekdays, .trigger-heatmap-grid { grid-template-columns: repeat(7,36px); gap:6px; }
            .trigger-cell, .heatmap-weekdays span { width:36px; height:36px; font-size:11px; }
            .trigger-legend { width:100%; margin-top:10px; flex-direction:row; gap:8px; align-items:center; }
            .legend-gradient { width:160px; height:10px; border-radius:6px; border:1px solid rgba(15,118,110,0.08); background: linear-gradient(90deg, var(--ui-surface-soft), var(--ui-surface-soft), var(--ui-accent)); }
        }
    </style>

    <script>
        (function () {
            function lerp(a, b, t) { return Math.round(a + (b - a) * t); }
            function parseColor(c) {
                if (!c) return [0,0,0];
                c = c.trim();
                if (c.startsWith('rgb')) {
                    var m = c.match(/\d+/g); return [parseInt(m[0]), parseInt(m[1]), parseInt(m[2])];
                }
                if (c.startsWith('#')) {
                    var hex = c.slice(1);
                    if (hex.length === 3) hex = hex.split('').map(function (s) { return s + s; }).join('');
                    return [parseInt(hex.slice(0,2),16), parseInt(hex.slice(2,4),16), parseInt(hex.slice(4,6),16)];
                }
                return [0,0,0];
            }

            var rootStyles = getComputedStyle(document.documentElement);
            var light = parseColor(rootStyles.getPropertyValue('--ui-surface-soft') || '#f8f7f3');
            var accent = parseColor(rootStyles.getPropertyValue('--ui-accent') || '#0f766e');
            function mixColor(percent) {
                return 'rgb(' + [lerp(light[0], accent[0], percent), lerp(light[1], accent[1], percent), lerp(light[2], accent[2], percent)].join(',') + ')';
            }

            fetch('@Url.Action("TriggerHeatmapData", "Home")')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    var grid = document.getElementById('triggerHeatmapGrid');
                    if (!grid) return;

                    grid.innerHTML = '';

                    var max = 0;
                    data.forEach(function (d) { if (d.count > max) max = d.count; });

                    data.forEach(function (d, idx) {
                        var day = new Date(d.day + 'T00:00:00Z');
                        var cnt = d.count || 0;
                        var ratio = max > 0 ? (cnt / max) : 0;
                        // compress the dynamic range so colors stay softer
                        var t = Math.pow(ratio, 0.85);
                        var color = mixColor(t);

                        var el = document.createElement('button');
                        el.type = 'button';
                        el.className = 'trigger-cell';
                        el.setAttribute('role','listitem');
                        el.setAttribute('data-day', d.day);
                        el.setAttribute('aria-label', d.day + ' — ' + cnt + ' triggers');
                        // apply background but keep element hidden for entrance animation
                        el.style.background = color;
                        el.style.opacity = 0;
                        el.style.transform = 'translateY(6px)';

                        var label = document.createElement('span');
                        label.className = 'day-label';
                        label.textContent = day.getUTCDate();
                        // decide label color based on computed background brightness for accessibility
                        try {
                            var bgRgb = parseColor(color);
                            var brightness = (bgRgb[0] * 299 + bgRgb[1] * 587 + bgRgb[2] * 114) / 1000; // 0-255
                            if (brightness < 140) {
                                label.style.color = '#ffffff';
                            } else {
                                label.style.color = getComputedStyle(document.documentElement).getPropertyValue('--ui-text-muted') || '#6b7280';
                            }
                        } catch (e) {
                            // fallback: keep muted text
                        }

                        el.appendChild(label);

                        // subtle emphasis for today (local date comparison)
                        var today = new Date();
                        if (day.getUTCFullYear() === today.getFullYear() && day.getUTCMonth() === today.getMonth() && day.getUTCDate() === today.getDate()) {
                            el.classList.add('today');
                        }

                        grid.appendChild(el);

                        // staggered entrance
                        (function (node, i) {
                            setTimeout(function () {
                                node.style.opacity = 1;
                                node.style.transform = 'translateY(0)';
                            }, 25 * (i % 12));
                        })(el, idx);
                    });
                })
                .catch(function () { console.warn('Unable to load trigger heatmap data'); });
        })();
    </script>
}
