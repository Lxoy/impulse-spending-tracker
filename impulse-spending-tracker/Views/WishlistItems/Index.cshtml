@model IReadOnlyList<WishlistItem>

@{
    ViewData["Title"] = "Wishlist Items";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index">Home</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Wishlist Items</li>
    </ol>
</nav>

<section class="mb-4">
    <h1 class="display-6 mb-2">Wishlist Items</h1>
    <p class="text-muted mb-0">Popis zeljenih artikala i njihov trenutni status.</p>
</section>

@if (!Model.Any())
{
    <div class="alert alert-info">Nema dostupnih wishlist stavki.</div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Naziv</th>
                        <th>Korisnik</th>
                        <th>Desired</th>
                        <th>Current</th>
                        <th>Priority</th>
                        <th>Dodano</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a asp-action="Details" asp-route-id="@item.Id">@item.Name</a>
                        </td>
                        <td>@(item.UserProfile is null ? "-" : $"{item.UserProfile.FirstName} {item.UserProfile.LastName}")</td>
                        <td>@item.DesiredPrice.ToString("F2") EUR</td>
                        <td>@item.CurrentPrice.ToString("F2") EUR</td>
                        <td>@item.Priority</td>
                        <td>@item.AddedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (item.IsPurchased)
                            {
                                <span class="badge text-bg-success">Purchased</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Open</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}