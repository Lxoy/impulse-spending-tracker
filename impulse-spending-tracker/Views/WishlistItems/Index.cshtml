@model IReadOnlyList<WishlistItem>

@{
    ViewData["Title"] = "Wishlist Items";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Wishlist Items</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="index-hero__grid">
            <div class="index-hero__copy">
                <p class="index-kicker mb-2">Intent queue</p>
                <h1 class="display-6 mb-2">Wishlist Items</h1>
                <p class="text-muted mb-0">List of desired items and their current status.</p>
            </div>
            <div class="index-hero__actions">
                <span class="index-count-chip" id="wishlistItemCount" data-singular="item" data-plural="items">@Model.Count items</span>
                <a class="btn btn-primary" asp-action="Create">Create wishlist item</a>
            </div>
        </div>

        <div class="index-search-panel">
            <div class="index-search-panel__header">
                <div>
                    <p class="index-search-panel__eyebrow mb-1">Live filter</p>
                    <p class="index-search-panel__title mb-0">Search by item name</p>
                </div>
                <span class="index-search-panel__hint">Results update as you type</span>
            </div>
        <input type="text"
               class="form-control index-search-input"
               placeholder="Search by item name..."
               aria-label="Search wishlist items by name"
               data-ajax-filter
               data-url="@Url.Action("Filter", "WishlistItems")"
               data-target="#wishlistItemTableBody"
               data-count-target="#wishlistItemCount"
               data-singular="item"
               data-plural="items"
               data-empty-message="No wishlist items match your search."
               data-column-count="6" />
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No wishlist items available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Purchase intent</p>
                    <p class="index-table-note">Wishlist priorities with current price tracking and readiness status.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>User</th>
                            <th>Current</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="wishlistItemTableBody">
                    @await Html.PartialAsync("_WishlistItemTableRows", Model)
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>