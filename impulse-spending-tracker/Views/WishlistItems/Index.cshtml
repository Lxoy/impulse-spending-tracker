@model IReadOnlyList<WishlistItem>

@{
    ViewData["Title"] = "Wishlist Items";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Wishlist Items</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <div>
                <p class="index-kicker mb-2">Intent queue</p>
                <h1 class="display-6 mb-2">Wishlist Items</h1>
                <p class="text-muted mb-0">List of desired items and their current status.</p>
            </div>
            <span class="index-count-chip">@Model.Count items</span>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No wishlist items available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Purchase intent</p>
                    <p class="index-table-note">Wishlist priorities with current price tracking and readiness status.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>User</th>
                            <th>Current</th>
                            <th>Priority</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        var priceDeltaRatio = item.DesiredPrice <= 0 ? 0m : (item.CurrentPrice - item.DesiredPrice) / item.DesiredPrice;
                        var priceSignalClass = item.CurrentPrice <= item.DesiredPrice
                            ? "list-signal list-signal--ok"
                            : priceDeltaRatio > 0.15m
                                ? "list-signal list-signal--danger"
                                : "list-signal list-signal--warn";
                        var prioritySignalClass = item.Priority switch
                        {
                            >= 4 => "list-signal list-signal--danger",
                            3 => "list-signal list-signal--warn",
                            _ => "list-signal list-signal--muted"
                        };

                        <tr>
                            <td class="fw-semibold">
                                <a class="index-link" asp-action="Details" asp-route-id="@item.Id">@item.Name</a>
                            </td>
                            <td>@(item.UserProfile is null ? "-" : $"{item.UserProfile.FirstName} {item.UserProfile.LastName}")</td>
                            <td><span class="@($"{priceSignalClass} list-signal--mono")">@item.CurrentPrice.ToString("F2") EUR</span></td>
                            <td><span class="@prioritySignalClass">@($"P{item.Priority}")</span></td>
                            <td>
                                @if (item.IsPurchased)
                                {
                                    <span class="list-signal list-signal--ok">Purchased</span>
                                }
                                else
                                {
                                    <span class="list-signal list-signal--brand">Open</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>