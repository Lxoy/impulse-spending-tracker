@model WishlistItem

@{
    ViewData["Title"] = "Wishlist Item Details";
}

<div class="details-shell">
    <nav aria-label="breadcrumb" class="details-breadcrumb mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="WishlistItems" asp-action="Index">Wishlist Items</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <section class="details-hero mb-3">
        <p class="details-kicker">Wishlist Tracking</p>
        <h1 class="details-title">@Model.Name</h1>
        <p class="details-subtitle">Priority, pricing, and readiness indicators for this planned purchase.</p>
        <div class="details-chip-row">
            <span class="details-chip">@Model.Priority Priority</span>
            <span class="details-chip">@(Model.IsPurchased ? "Purchased" : "Open")</span>
            <span class="details-chip">Desired @Model.DesiredPrice.ToString("F2") EUR</span>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Wishlist Context</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>User</dt>
                            <dd>@(Model.UserProfile is null ? "-" : $"{Model.UserProfile.FirstName} {Model.UserProfile.LastName}")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Priority</dt>
                            <dd>@Model.Priority</dd>
                        </div>
                        <div class="details-row">
                            <dt>Status</dt>
                            <dd>@(Model.IsPurchased ? "Purchased" : "Open")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Added at</dt>
                            <dd>@Model.AddedAt.ToString("yyyy-MM-dd")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Target date</dt>
                            <dd>@(Model.TargetPurchaseDate.HasValue ? Model.TargetPurchaseDate.Value.ToString("yyyy-MM-dd") : "-")</dd>
                        </div>
                    </dl>
                </div>
            </article>

            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Price and Reasoning</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>Desired price</dt>
                            <dd>@Model.DesiredPrice.ToString("F2") EUR</dd>
                        </div>
                        <div class="details-row">
                            <dt>Current price</dt>
                            <dd>@Model.CurrentPrice.ToString("F2") EUR</dd>
                        </div>
                        <div class="details-row">
                            <dt>Reason</dt>
                            <dd>@(string.IsNullOrWhiteSpace(Model.Reason) ? "-" : Model.Reason)</dd>
                        </div>
                        <div class="details-row">
                            <dt>Link</dt>
                            <dd>
                                @if (string.IsNullOrWhiteSpace(Model.LinkUrl))
                                {
                                    <span>-</span>
                                }
                                else
                                {
                                    <a class="details-link-inline" href="@Model.LinkUrl" target="_blank" rel="noopener noreferrer">@Model.LinkUrl</a>
                                }
                            </dd>
                        </div>
                    </dl>
                </div>
            </article>
        </div>

        <div class="col-12 col-lg-4">
            <aside class="details-aside mb-3">
                <h2 class="h6 mb-2">Quick Hint</h2>
                <p class="mb-0 text-muted">If current price is close to desired price but status stays open, review whether need level is truly high.</p>
            </aside>
        </div>
    </div>

    <div class="details-actions">
        <a asp-action="Index" class="btn btn-outline-primary">Back to list</a>
    </div>
</div>
