@model WishlistItem

@{
    ViewData["Title"] = "Wishlist Item Details";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="WishlistItems" asp-action="Index">Wishlist Items</a></li>
        <li class="breadcrumb-item active" aria-current="page">Details</li>
    </ol>
</nav>

<section class="mb-4">
    <h1 class="display-6 mb-2">@Model.Name</h1>
    <p class="text-muted mb-0">Detalji wishlist stavke i planirane kupnje.</p>
</section>

<div class="card mb-3"><div class="card-body"><dl class="row mb-0">
    <dt class="col-sm-4 text-muted">Korisnik</dt>
    <dd class="col-sm-8 fw-semibold">@(Model.UserProfile is null ? "-" : $"{Model.UserProfile.FirstName} {Model.UserProfile.LastName}")</dd>
    <dt class="col-sm-4 text-muted">Priority</dt>
    <dd class="col-sm-8 fw-semibold">@Model.Priority</dd>
    <dt class="col-sm-4 text-muted">Status</dt>
    <dd class="col-sm-8 fw-semibold">@(Model.IsPurchased ? "Purchased" : "Open")</dd>
    <dt class="col-sm-4 text-muted">Dodano</dt>
    <dd class="col-sm-8 fw-semibold">@Model.AddedAt.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-4 text-muted">Target date</dt>
    <dd class="col-sm-8 fw-semibold">@(Model.TargetPurchaseDate.HasValue ? Model.TargetPurchaseDate.Value.ToString("yyyy-MM-dd") : "-")</dd>
</dl></div></div>

<div class="card mb-3"><div class="card-body"><dl class="row mb-0">
    <dt class="col-sm-4 text-muted">Desired price</dt>
    <dd class="col-sm-8 fw-semibold">@Model.DesiredPrice.ToString("F2") EUR</dd>
    <dt class="col-sm-4 text-muted">Current price</dt>
    <dd class="col-sm-8 fw-semibold">@Model.CurrentPrice.ToString("F2") EUR</dd>
    <dt class="col-sm-4 text-muted">Reason</dt>
    <dd class="col-sm-8 fw-semibold">@Model.Reason</dd>
    <dt class="col-sm-4 text-muted">Link</dt>
    <dd class="col-sm-8 fw-semibold">
        @if (string.IsNullOrWhiteSpace(Model.LinkUrl))
        {
            <span>-</span>
        }
        else
        {
            <a href="@Model.LinkUrl" target="_blank" rel="noopener noreferrer">@Model.LinkUrl</a>
        }
    </dd>
</dl></div></div>

<a asp-action="Index" class="btn btn-outline-primary">Natrag na listu</a>
