@model IReadOnlyList<Purchase>

@{
    ViewData["Title"] = "Purchases";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Purchases</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="index-hero__grid">
            <div class="index-hero__copy">
                <p class="index-kicker mb-2">Live feed</p>
                <h1 class="display-6 mb-2">Purchases</h1>
                <p class="text-muted mb-0">List of all recorded purchases and impulse events.</p>
            </div>
            <div class="index-hero__actions">
                <span class="index-count-chip" id="purchaseCount" data-singular="purchase" data-plural="purchases">@Model.Count purchases</span>
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="btn btn-primary" asp-action="Create">Create purchase</a>
                }
            </div>
        </div>

        <div class="index-search-panel">
            <div class="index-search-panel__header">
                <div>
                    <p class="index-search-panel__eyebrow mb-1">Live filter</p>
                    <p class="index-search-panel__title mb-0">Search by purchase title</p>
                </div>
                <span class="index-search-panel__hint">Results update as you type</span>
            </div>
        <input type="text"
               class="form-control index-search-input"
               placeholder="Search by purchase title..."
               aria-label="Search purchases by title"
               data-ajax-filter
               data-url="@Url.Action("Filter", "Purchases")"
               data-target="#purchaseTableBody"
               data-count-target="#purchaseCount"
               data-singular="purchase"
               data-plural="purchases"
               data-empty-message="No purchases match your search."
               data-column-count="6" />
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No purchases available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Purchase timeline</p>
                    <p class="index-table-note">Newest purchases first, then higher amounts within the same period.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>User</th>
                            <th>Merchant</th>
                            <th>Amount</th>
                            <th>Purchase Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="purchaseTableBody">
                    @await Html.PartialAsync("_PurchaseTableRows", Model)
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>