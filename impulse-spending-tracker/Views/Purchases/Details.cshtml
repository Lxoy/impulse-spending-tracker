@model Purchase

@{
    ViewData["Title"] = "Purchase Details";
}

<div class="details-shell">
    <nav aria-label="breadcrumb" class="details-breadcrumb mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Purchases" asp-action="Index">Purchases</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <section class="details-hero mb-3">
        <p class="details-kicker">Purchase Record</p>
        <h1 class="details-title">@Model.Title</h1>
        <p class="details-subtitle">Detailed context around amount, trigger, and emotional state at the moment of purchase.</p>
        <div class="details-chip-row">
            <span class="details-chip">@Model.Amount.ToString("F2") @Model.Currency</span>
            <span class="details-chip">Trigger @(Model.TriggerTypeTag?.Name ?? Model.TriggerType.ToString())</span>
            <span class="details-chip">Need @Model.NeedLevel / 10</span>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Purchase Snapshot</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>Amount</dt>
                            <dd>@Model.Amount.ToString("F2") @Model.Currency</dd>
                        </div>
                        <div class="details-row">
                            <dt>Purchased at</dt>
                            <dd>@Model.PurchasedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Trigger</dt>
                            <dd>@(Model.TriggerTypeTag?.Name ?? Model.TriggerType.ToString())</dd>
                        </div>
                        <div class="details-row">
                            <dt>Need level</dt>
                            <dd>@Model.NeedLevel</dd>
                        </div>
                        <div class="details-row">
                            <dt>Mood before purchase</dt>
                            <dd>@Model.MoodBeforePurchase</dd>
                        </div>
                    </dl>
                </div>
            </article>

            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Linked Context</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>User</dt>
                            <dd>@(Model.UserProfile is null ? "-" : $"{Model.UserProfile.FirstName} {Model.UserProfile.LastName}")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Merchant</dt>
                            <dd>@(Model.Merchant?.Name ?? "-")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Installments</dt>
                            <dd>@Model.Installments</dd>
                        </div>
                        <div class="details-row">
                            <dt>Notes</dt>
                            <dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</dd>
                        </div>
                    </dl>
                </div>
            </article>
        </div>

        <div class="col-12 col-lg-4">
            <aside class="details-aside mb-3">
                <h2 class="h6 mb-2">Quick Hint</h2>
                <p class="mb-0 text-muted">Low need-level purchases with high amount often indicate a stronger impulse event worth reviewing.</p>
            </aside>
            <aside class="details-aside card mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Attachments</h2>
                    <div id="purchaseAttachmentList" data-list-url="@Url.Action("GetAttachments", "Purchases", new { id = Model.Id })">
                        <div class="text-muted">Loading attachments...</div>
                    </div>
                </div>
            </aside>
        </div>
    </div>

    <div class="details-actions">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit purchase</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        <a asp-action="Index" class="btn btn-outline-primary">Back to list</a>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        function loadAttachments() {
            var list = document.getElementById("purchaseAttachmentList");
            if (!list) return;
            var url = list.getAttribute("data-list-url");

            fetch(url, {
                method: "GET",
                headers: { "X-Requested-With": "XMLHttpRequest" }
            })
                .then(function (response) { return response.text(); })
                .then(function (html) { list.innerHTML = html; })
                .catch(function () {
                    list.innerHTML = "<div class='alert alert-warning mb-0'>Unable to load attachments.</div>";
                });
        }

        function deleteAttachment(id) {
            var body = new URLSearchParams({ id: id });

            fetch("@Url.Action("DeleteAttachment", "Purchases")", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                    "X-Requested-With": "XMLHttpRequest"
                },
                body: body
            })
                .then(function (response) {
                    if (!response.ok) {
                        throw new Error("Delete failed");
                    }

                    return response.json();
                })
                .then(function () { loadAttachments(); })
                .catch(function () {
                    alert("Unable to delete attachment.");
                });
        }

        document.addEventListener("DOMContentLoaded", function () {
            loadAttachments();
        });
    </script>
}
