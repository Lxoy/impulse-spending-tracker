@model IReadOnlyList<impulse_spending_tracker.Models.PurchaseAttachment>

@if (!Model.Any())
{
    <div class="alert alert-light border" role="status">
        No files uploaded yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>File</th>
                    <th>Type</th>
                    <th>Size</th>
                    <th>Uploaded</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var attachment in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="Purchases"
                               asp-action="AttachmentFile"
                               asp-route-id="@attachment.Id"
                               target="_blank"
                               rel="noopener noreferrer">@attachment.FileName</a>
                        </td>
                        <td>@attachment.ContentType</td>
                        <td>@(((double)attachment.FileSize / 1024d).ToString("F1")) KB</td>
                        <td>@attachment.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <button
                                type="button"
                                class="btn btn-outline-danger btn-sm"
                                onclick="deleteAttachment(@attachment.Id)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
