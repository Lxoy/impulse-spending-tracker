@model IReadOnlyList<SpendingSession>

@{
    ViewData["Title"] = "Spending Sessions";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Spending Sessions</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <div>
                <p class="index-kicker mb-2">Behavior traces</p>
                <h1 class="display-6 mb-2">Spending Sessions</h1>
                <p class="text-muted mb-0">Overview of shopping sessions and spending outcomes.</p>
            </div>
            <span class="index-count-chip">@Model.Count sessions</span>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No spending sessions available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Session outcomes</p>
                    <p class="index-table-note">Per-session comparison of planned budget, spent amount, and checkout result.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Start</th>
                            <th>User</th>
                            <th>Platform</th>
                            <th>Budget</th>
                            <th>Spent</th>
                            <th>Checkout</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var session in Model)
                    {
                        var utilization = session.SessionBudget <= 0 ? -1m : session.SpentAmount / session.SessionBudget;
                        var spentSignalClass = session.SessionBudget <= 0
                            ? "list-signal list-signal--muted"
                            : utilization > 1m
                                ? "list-signal list-signal--danger"
                                : utilization >= 0.8m
                                    ? "list-signal list-signal--warn"
                                    : "list-signal list-signal--ok";

                        <tr>
                            <td class="fw-semibold">
                                <a class="index-link" asp-action="Details" asp-route-id="@session.Id">@session.StartedAt.ToString("yyyy-MM-dd HH:mm")</a>
                            </td>
                            <td>@(session.UserProfile is null ? "-" : $"{session.UserProfile.FirstName} {session.UserProfile.LastName}")</td>
                            <td>@session.Platform</td>
                            <td><span class="list-signal list-signal--muted list-signal--mono">@session.SessionBudget.ToString("F2") EUR</span></td>
                            <td><span class="@($"{spentSignalClass} list-signal--mono")">@session.SpentAmount.ToString("F2") EUR</span></td>
                            <td>
                                @if (session.CheckoutCompleted)
                                {
                                    <span class="list-signal list-signal--ok">Completed</span>
                                }
                                else
                                {
                                    <span class="list-signal list-signal--warn">Pending</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>