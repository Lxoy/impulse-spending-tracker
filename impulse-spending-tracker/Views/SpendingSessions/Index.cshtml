@model IReadOnlyList<SpendingSession>

@{
    ViewData["Title"] = "Spending Sessions";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Spending Sessions</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="index-hero__grid">
            <div class="index-hero__copy">
                <p class="index-kicker mb-2">Behavior traces</p>
                <h1 class="display-6 mb-2">Spending Sessions</h1>
                <p class="text-muted mb-0">Overview of shopping sessions and spending outcomes.</p>
            </div>
            <div class="index-hero__actions">
                <span class="index-count-chip" id="spendingSessionCount" data-singular="session" data-plural="sessions">@Model.Count sessions</span>
                <a class="btn btn-primary" asp-action="Create">Create session</a>
            </div>
        </div>

        <div class="index-search-panel">
            <div class="index-search-panel__header">
                <div>
                    <p class="index-search-panel__eyebrow mb-1">Live filter</p>
                    <p class="index-search-panel__title mb-0">Search by user, platform, or channel</p>
                </div>
                <span class="index-search-panel__hint">Results update as you type</span>
            </div>
        <input type="text"
               class="form-control index-search-input"
               placeholder="Search by user, platform, or channel..."
               aria-label="Search spending sessions"
               data-ajax-filter
               data-url="@Url.Action("Filter", "SpendingSessions")"
               data-target="#spendingSessionTableBody"
               data-count-target="#spendingSessionCount"
               data-singular="session"
               data-plural="sessions"
               data-empty-message="No spending sessions match your search."
               data-column-count="7" />
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No spending sessions available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Session outcomes</p>
                    <p class="index-table-note">Per-session comparison of planned budget, spent amount, and checkout result.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Start</th>
                            <th>User</th>
                            <th>Platform</th>
                            <th>Budget</th>
                            <th>Spent</th>
                            <th>Checkout</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="spendingSessionTableBody">
                    @await Html.PartialAsync("_SpendingSessionTableRows", Model)
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>