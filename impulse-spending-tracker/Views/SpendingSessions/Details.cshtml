@model SpendingSession

@{
    ViewData["Title"] = "Spending Session Details";
}

<div class="details-shell">
    <nav aria-label="breadcrumb" class="details-breadcrumb mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="SpendingSessions" asp-action="Index">Spending Sessions</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <section class="details-hero mb-3">
        <p class="details-kicker">Session Insights</p>
        <h1 class="details-title">Session @Model.StartedAt.ToString("yyyy-MM-dd HH:mm")</h1>
        <p class="details-subtitle">Timeline and conversion behavior for this tracked shopping session.</p>
        <div class="details-chip-row">
            <span class="details-chip">Budget @Model.SessionBudget.ToString("F2") EUR</span>
            <span class="details-chip">Spent @Model.SpentAmount.ToString("F2") EUR</span>
            <span class="details-chip">@(Model.CheckoutCompleted ? "Checkout Completed" : "Checkout Not Completed")</span>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Session Timeline</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>Started at</dt>
                            <dd>@Model.StartedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Ended at</dt>
                            <dd>@(Model.EndedAt.HasValue ? Model.EndedAt.Value.ToString("yyyy-MM-dd HH:mm") : "-")</dd>
                        </div>
                        <div class="details-row">
                            <dt>Platform</dt>
                            <dd>@Model.Platform</dd>
                        </div>
                        <div class="details-row">
                            <dt>Channel</dt>
                            <dd>@Model.Channel</dd>
                        </div>
                    </dl>
                </div>
            </article>

            <article class="details-panel card border-0 mb-3">
                <div class="card-body">
                    <h2 class="details-panel-title">Session Metrics</h2>
                    <dl class="details-dl">
                        <div class="details-row">
                            <dt>Session budget</dt>
                            <dd>@Model.SessionBudget.ToString("F2") EUR</dd>
                        </div>
                        <div class="details-row">
                            <dt>Spent amount</dt>
                            <dd>@Model.SpentAmount.ToString("F2") EUR</dd>
                        </div>
                        <div class="details-row">
                            <dt>Items viewed</dt>
                            <dd>@Model.ItemsViewed</dd>
                        </div>
                        <div class="details-row">
                            <dt>Items added to cart</dt>
                            <dd>@Model.ItemsAddedToCart</dd>
                        </div>
                        <div class="details-row">
                            <dt>Checkout completed</dt>
                            <dd>@(Model.CheckoutCompleted ? "Yes" : "No")</dd>
                        </div>
                        <div class="details-row">
                            <dt>User</dt>
                            <dd>@(Model.UserProfile is null ? "-" : $"{Model.UserProfile.FirstName} {Model.UserProfile.LastName}")</dd>
                        </div>
                    </dl>
                </div>
            </article>
        </div>

        <div class="col-12 col-lg-4">
            <aside class="details-aside mb-3">
                <h2 class="h6 mb-2">Quick Hint</h2>
                <p class="mb-0 text-muted">Compare viewed items versus added-to-cart count to identify hesitation points in the shopping flow.</p>
            </aside>
        </div>
    </div>

    <div class="details-actions">
        <a asp-action="Index" class="btn btn-outline-primary">Back to list</a>
    </div>
</div>
