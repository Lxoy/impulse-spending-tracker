@model SpendingSession

@{
    ViewData["Title"] = "Create Spending Session";
}

<div class="form-shell">
    <nav aria-label="breadcrumb" class="form-breadcrumb mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Spending Sessions</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create</li>
        </ol>
    </nav>

    <section class="form-hero mb-3">
        <p class="form-kicker">Spending Sessions</p>
        <h1 class="form-title">Create Spending Session</h1>
        <p class="form-subtitle">Register a new browsing and checkout timeline.</p>
    </section>

    <section class="form-surface card border-0">
        <div class="card-body">
            <form asp-action="Create" method="post" class="form-grid row g-3" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-12 col-md-6 position-relative">
                    @await Html.PartialAsync("_AutocompleteDropdown", new AutocompleteDropdownModel
                    {
                        InputName = nameof(Model.UserProfileId),
                        ValidationMessageFor = nameof(Model.UserProfileId),
                        Label = "User",
                        Placeholder = "Search users...",
                        SearchUrl = Url.Action("Users", "Lookup") ?? "/lookup/users",
                        EmptyMessage = "No users found."
                    })
                </div>
                <div class="col-12 col-md-6">
                    @await Html.PartialAsync("_DatePickerControl", Model.EndedAt, new ViewDataDictionary(ViewData) { { "IncludeTime", true }, { "For", nameof(Model.EndedAt) } })
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Platform" class="form-label"></label>
                    <input asp-for="Platform" class="form-control" placeholder="e.g., Web" />
                    <span asp-validation-for="Platform" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Channel" class="form-label"></label>
                    <input asp-for="Channel" class="form-control" placeholder="e.g., Browser / Mobile app" />
                    <span asp-validation-for="Channel" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="SessionBudget" class="form-label"></label>
                    <input asp-for="SessionBudget" class="form-control" placeholder="e.g., 100.00" />
                    <span asp-validation-for="SessionBudget" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="CheckoutCompleted" class="form-check-input" />
                        <label asp-for="CheckoutCompleted" class="form-check-label"></label>
                    </div>
                    <span asp-validation-for="CheckoutCompleted" class="text-danger"></span>
                </div>

                <div class="col-12 form-actions d-flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="btn btn-primary">Create session</button>
                    <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
