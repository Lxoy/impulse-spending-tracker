@model BudgetPlan

@{
    ViewData["Title"] = "Edit Budget Plan";
}

<div class="form-shell">
    <nav aria-label="breadcrumb" class="form-breadcrumb mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Budget Plans</a></li>
            <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">Details</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>

    <section class="form-hero mb-3">
        <p class="form-kicker">Budget Plans</p>
        <h1 class="form-title">Edit Budget Plan</h1>
        <p class="form-subtitle">Adjust limits and state while keeping timeline continuity.</p>
    </section>

    <section class="form-surface card border-0">
        <div class="card-body">
            <form asp-action="Edit" method="post" class="form-grid row g-3" novalidate>
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-12 col-md-6 position-relative">
                    @await Html.PartialAsync("_AutocompleteDropdown", new AutocompleteDropdownModel
                    {
                        InputName = nameof(Model.UserProfileId),
                        ValidationMessageFor = nameof(Model.UserProfileId),
                        Label = "User",
                        Placeholder = "Search users...",
                        SearchUrl = Url.Action("Users", "Lookup") ?? "/lookup/users",
                        EmptyMessage = "No users found.",
                        SelectedId = Model.UserProfileId,
                        SelectedText = Model.UserProfile is null ? string.Empty : $"{Model.UserProfile.FirstName} {Model.UserProfile.LastName} ({Model.UserProfile.Email})"
                    })
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Monthly groceries" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    @await Html.PartialAsync("_DatePickerControl", Model.ValidFrom, new ViewDataDictionary(ViewData) { { "For", nameof(Model.ValidFrom) } })
                </div>
                <div class="col-12 col-md-6">
                    @await Html.PartialAsync("_DatePickerControl", Model.ValidTo, new ViewDataDictionary(ViewData) { { "For", nameof(Model.ValidTo) }, { "ValidationFrom", nameof(Model.ValidFrom) }, { "ValidationMessage", "Valid To date must be on or after Valid From date." } })
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="MonthlyLimit" class="form-label"></label>
                    <input asp-for="MonthlyLimit" type="number" min="0.01" step="0.01" class="form-control" placeholder="e.g., 500.00" />
                    <span asp-validation-for="MonthlyLimit" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="ImpulseCapPercentage" class="form-label"></label>
                    <input asp-for="ImpulseCapPercentage" type="number" min="0" max="100" step="0.01" class="form-control" placeholder="e.g., 15" />
                    <span asp-validation-for="ImpulseCapPercentage" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="EssentialCategoryLimit" class="form-label"></label>
                    <input asp-for="EssentialCategoryLimit" type="number" min="0" step="0.01" class="form-control" placeholder="e.g., 300.00" />
                    <span asp-validation-for="EssentialCategoryLimit" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="DiscretionaryCategoryLimit" class="form-label"></label>
                    <input asp-for="DiscretionaryCategoryLimit" type="number" min="0" step="0.01" class="form-control" placeholder="e.g., 200.00" />
                    <span asp-validation-for="DiscretionaryCategoryLimit" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                    <span asp-validation-for="IsActive" class="text-danger"></span>
                </div>

                <div class="col-12 form-actions d-flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="btn btn-primary">Save changes</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back to details</a>
                    <a asp-action="Index" class="btn btn-outline-primary">Back to list</a>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
