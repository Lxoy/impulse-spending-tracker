@model IReadOnlyList<BudgetPlan>

@{
    ViewData["Title"] = "Budget Plans";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Budget Plans</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="index-hero__grid">
            <div class="index-hero__copy">
                <p class="index-kicker mb-2">Planning</p>
                <h1 class="display-6 mb-2">Budget Plans</h1>
                <p class="text-muted mb-0">Overview of spending plans and limits per user.</p>
            </div>
            <div class="index-hero__actions">
                <span class="index-count-chip" id="budgetPlanCount" data-singular="plan" data-plural="plans">@Model.Count plans</span>
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="btn btn-primary" asp-action="Create">Create plan</a>
                }
            </div>
        </div>

        <div class="index-search-panel">
            <div class="index-search-panel__header">
                <div>
                    <p class="index-search-panel__eyebrow mb-1">Live filter</p>
                    <p class="index-search-panel__title mb-0">Search by plan name</p>
                </div>
                <span class="index-search-panel__hint">Results update as you type</span>
            </div>
        <input type="text"
               class="form-control index-search-input"
               placeholder="Search by plan name..."
               aria-label="Search budget plans by name"
               data-ajax-filter
               data-url="@Url.Action("Filter", "BudgetPlans")"
               data-target="#budgetPlanTableBody"
               data-count-target="#budgetPlanCount"
               data-singular="plan"
               data-plural="plans"
               data-empty-message="No budget plans match your search."
               data-column-count="7" />
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No budget plans available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Monthly guardrails</p>
                    <p class="index-table-note">Plan limits, active status, and validity window for each user profile.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Plan Name</th>
                            <th>User</th>
                            <th>Valid From</th>
                            <th>Valid To</th>
                            <th>Monthly Limit</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="budgetPlanTableBody">
                    @await Html.PartialAsync("_BudgetPlanTableRows", Model)
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>