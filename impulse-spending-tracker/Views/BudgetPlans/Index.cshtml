@model IReadOnlyList<BudgetPlan>

@{
    ViewData["Title"] = "Budget Plans";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index">Home</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Budget Plans</li>
    </ol>
</nav>

<section class="mb-4">
    <h1 class="display-6 mb-2">Budget Plans</h1>
    <p class="text-muted mb-0">Lista planova potrosnje i limita po korisniku.</p>
</section>

@if (!Model.Any())
{
    <div class="alert alert-info">Nema dostupnih budget planova.</div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Naziv plana</th>
                        <th>Korisnik</th>
                        <th>Vrijedi od</th>
                        <th>Vrijedi do</th>
                        <th>Monthly limit</th>
                        <th>Impulse cap</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var plan in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a asp-action="Details" asp-route-id="@plan.Id">@plan.Name</a>
                        </td>
                        <td>@(plan.UserProfile is null ? "-" : $"{plan.UserProfile.FirstName} {plan.UserProfile.LastName}")</td>
                        <td>@plan.ValidFrom.ToString("yyyy-MM-dd")</td>
                        <td>@plan.ValidTo.ToString("yyyy-MM-dd")</td>
                        <td>@plan.MonthlyLimit.ToString("F2") EUR</td>
                        <td>@plan.ImpulseCapPercentage.ToString("F0")%</td>
                        <td>
                            @if (plan.IsActive)
                            {
                                <span class="badge text-bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Inactive</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}