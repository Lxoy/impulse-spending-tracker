@model IReadOnlyList<BudgetPlan>

@{
    ViewData["Title"] = "Budget Plans";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Budget Plans</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <div>
                <p class="index-kicker mb-2">Planning</p>
                <h1 class="display-6 mb-2">Budget Plans</h1>
                <p class="text-muted mb-0">Overview of spending plans and limits per user.</p>
            </div>
            <span class="index-count-chip">@Model.Count plans</span>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No budget plans available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <p class="index-table-title">Monthly guardrails</p>
                <span class="badge-soft">Active monitoring</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Plan Name</th>
                            <th>User</th>
                            <th>Valid From</th>
                            <th>Valid To</th>
                            <th>Monthly Limit</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var plan in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a class="index-link" asp-action="Details" asp-route-id="@plan.Id">@plan.Name</a>
                            </td>
                            <td>@(plan.UserProfile is null ? "-" : $"{plan.UserProfile.FirstName} {plan.UserProfile.LastName}")</td>
                            <td>@plan.ValidFrom.ToString("yyyy-MM-dd")</td>
                            <td>@plan.ValidTo.ToString("yyyy-MM-dd")</td>
                            <td>@plan.MonthlyLimit.ToString("F2") EUR</td>
                            <td>
                                @if (plan.IsActive)
                                {
                                    <span class="badge text-bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>