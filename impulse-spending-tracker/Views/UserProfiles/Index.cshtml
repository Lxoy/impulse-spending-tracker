@model IReadOnlyList<UserProfile>

@{
    ViewData["Title"] = "User Profiles";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">User Profiles</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <div>
                <p class="index-kicker mb-2">People layer</p>
                <h1 class="display-6 mb-2">User Profiles</h1>
                <p class="text-muted mb-0">Overview of all users from the mock repository source.</p>
            </div>
            <span class="index-count-chip">@Model.Count users</span>
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No user profiles available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <p class="index-table-title">Profile overview</p>
                <span class="badge-soft">Risk baseline</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Risk score</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a class="index-link" asp-action="Details" asp-route-id="@user.Id">@user.FirstName @user.LastName</a>
                            </td>
                            <td>@user.Email</td>
                            <td>@user.RiskToleranceScore</td>
                            <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>