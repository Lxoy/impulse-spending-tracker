@model IReadOnlyList<UserProfile>

@{
    ViewData["Title"] = "User Profiles";
}

<div class="index-shell">
    <nav aria-label="breadcrumb" class="mb-3 index-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">User Profiles</li>
        </ol>
    </nav>

    <section class="index-hero mb-4">
        <div class="index-hero__grid">
            <div class="index-hero__copy">
                <p class="index-kicker mb-2">People layer</p>
                <h1 class="display-6 mb-2">User Profiles</h1>
                <p class="text-muted mb-0">Overview of all users from the EF-backed repository source.</p>
            </div>
            <div class="index-hero__actions">
                <span class="index-count-chip" id="userProfileCount" data-singular="user" data-plural="users">@Model.Count users</span>
            </div>
        </div>

        <div class="index-search-panel">
            <div class="index-search-panel__header">
                <div>
                    <p class="index-search-panel__eyebrow mb-1">Live filter</p>
                    <p class="index-search-panel__title mb-0">Search by first or last name</p>
                </div>
                <span class="index-search-panel__hint">Results update as you type</span>
            </div>
        <input type="text"
               class="form-control index-search-input"
               placeholder="Search by first or last name..."
               aria-label="Search user profiles by name"
               data-ajax-filter
               data-url="@Url.Action("Filter", "UserProfiles")"
               data-target="#userProfileTableBody"
               data-count-target="#userProfileCount"
               data-singular="user"
               data-plural="users"
               data-empty-message="No user profiles match your search."
               data-column-count="5" />
        </div>
    </section>

    @if (!Model.Any())
    {
        <div class="alert alert-info index-empty">No user profiles available.</div>
    }
    else
    {
        <div class="index-surface card border-0">
            <div class="index-table-head">
                <div>
                    <p class="index-table-title">Profile overview</p>
                    <p class="index-table-note">Users sorted by last name, with current risk score and creation date.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 index-table">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Risk score</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="userProfileTableBody">
                    @await Html.PartialAsync("_UserProfileTableRows", Model)
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>